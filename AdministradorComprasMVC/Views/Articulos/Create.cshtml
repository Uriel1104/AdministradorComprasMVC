@{
}
@model AdministradorComprasMVC.Models.Articulo


<form id="guardarArticulo" asp-action="Create" asp-controller="Articulos">
  <div class="form-group">
    <label for="">Nombre</label>
    <input type="text" class="form-control" id=""  placeholder="Nombre del Producto" asp-for="Nombre">
  </div>
  <div class="form-group">
    <label for="">Descripcion</label>
    <input type="text" class="form-control" id="" placeholder="Descripcion" asp-for="Descripcion">
  </div>
  <div class="form-group">
    <label for="">Stock</label>
    <input type="text" class="form-control" id="" placeholder="Stock" asp-for="Stock">
  </div>
  <hr />
  <div class="form-inline">
      <select asp-for="@Model.CategoriasId" asp-items="@ViewBag.Categorias"
      class="form-control" id="Id"></select>
  </div>
  <br />
  <div class="form-inline">
      <select asp-for="@Model.ProveedorId" asp-items="@ViewBag.Proveedor"
      class="form-control" id="Id"></select>
  </div>

  <button type="submit" class="btn btn-primary">Enviar</button>
</form>
